  "keyFeatures": [
    "Calendar-based entry management with mood tracking",
    "Automatic sentiment analysis using VADER NLP",
    "Streak tracking and achievement badges",
    "AI-powered insights and summaries via Groq",
    "Interactive dashboards with Chart.js visualizations",
    "100% local data storage with JSON export/import",
    "Dark/light theme support",
    "Smart writing prompts and AI text polishing"
  ],
  "publicApiSurface": [
    "GET /api/entries - Get all journal entries",
    "POST /api/entries/<date> - Create or update entry",
    "DELETE /api/entries/<date> - Delete entry",
    "GET /api/stats - Get journaling statistics and streak data",
    "GET /api/insights/charts - Get chart visualization data",
    "GET /api/insights/summary - Get AI-generated monthly summary",
    "GET /api/greeting - Get personalized greeting",
    "POST /api/rewrite - AI text polishing",
    "GET /api/weekly - Weekly insights",
    "GET /api/monthly - Monthly summary",
    "GET /api/export - Export journal data",
    "POST /api/import - Import journal data"
  ]
